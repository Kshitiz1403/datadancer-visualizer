{
  "name": "datadancer-visualizer",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "React library for visualizing Serverless Workflow executions",
  "keywords": ["serverless-workflow", "workflow", "visualizer", "react", "debug"],
  "files": ["dist"],
  "main": "./dist/datadancer-visualizer.umd.cjs",
  "module": "./dist/datadancer-visualizer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/datadancer-visualizer.js",
      "require": "./dist/datadancer-visualizer.umd.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/datadancer-visualizer.css"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@xyflow/react": ">=12.0.0",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.4"
  }
}
